# Rapid API Configuration
# Copy this file to .env and fill in your actual credentials

# API Credentials (required)
RAPID_API_USER=your_username_here
RAPID_API_PASSWORD=your_password_here

# API URL (optional - defaults to production if not set)
# Production: https://eastprodapi.rrms.com/RestApIProd/api/
# Development: https://eastdevapi.rrms.com/RestApiDev/api/
RAPID_API_URL=https://eastprodapi.rrms.com/RestApIProd/api/

# Example site/group IDs for testing (optional)
# RAPID_TEST_SITE_NUM=123
# RAPID_TEST_SITE_GROUP=456