	"item": [
		{
			"name": "UserLogin",
			"event": [
				{
					"listen": "prerequest",
					"script": {
						"exec": [
							"pm.collectionVariables.set(\"URL\", \"https://eastdevapi.rrms.com/RestApiDev/api/\");",
							"pm.collectionVariables.set(\"UserName\", \"xxx\");",
							"pm.collectionVariables.set(\"Password\", \"xxx\");",
							""
						],
						"type": "text/javascript"
					}
				},
				{
					"listen": "test",
					"script": {
						"exec": [
							" var jsonData = pm.response.json();",
							" if(jsonData.Success === true) {",
							"    pm.collectionVariables.set(\"SessionNum\", jsonData.OutputParameter.SessionNum);",
							"    pm.collectionVariables.set(\"SessionPassword\", jsonData.OutputParameter.SessionPassword);",
							" }",
							"",
							"pm.test(\"Success = true\", function () {",
							"    pm.expect(jsonData.Success).to.eql(true);",
							"",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					},
					{
						"key": "Connection",
						"value": "close",
						"type": "text"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\r\n    \"Username\": \"{{UserName}}\",\r\n    \"Password\": \"{{Password}}\",\r\n    \"NewPassword\": null,\r\n    \"ApplicationName\": null,\r\n    \"ApplicationVersion\": null,\r\n    \"ClientPlatform\": null\r\n}\r\n"
				},
				"url": {
					"raw": "{{URL}}Login/UserLogin",
					"host": [
						"{{URL}}Login"
					],
					"path": [
						"UserLogin"
					]
				},
				"description": "UserLogin is used to log into the system. It returns a SessionNum and SessionPassword that will be used for all subsequent calls."
			},
			"response": []
		},
